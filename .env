# Copy file này thành .env rồi chỉnh giá trị

# Proxy dùng chung cho cả 2 tier (optional)
PROXY_URL=

# --- Debug qua VNC ---
# Đặt =1 để bật x11vnc, xem trực tiếp Chrome đang render gì trong container
VNC_ENABLED=1
# Nên luôn đặt password khi bật VNC, kể cả chạy local, tránh port 5900 bị quét trúng
VNC_PASSWORD=changeme123
